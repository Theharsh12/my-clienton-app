{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-eval' 'unsafe-inline' https://cdn.mxpnl.com https://www.googletagmanager.com https://www.google-analytics.com; object-src 'none';"
        }
      ]
    }
  ]
}